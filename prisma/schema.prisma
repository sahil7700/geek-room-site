generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Event {
  id               String              @id @default(uuid())
  title            String
  description      String
  date             DateTime
  location         String
  registrationLink String?
  image            String
  status           String
  category         String?
  time             String?
  registrationOpen Boolean             @default(true)
  gallery          String[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  registrations    EventRegistration[]
  FormField        FormField[]
  submissions      FormSubmission[]
  winners          Winner[]
}

model Winner {
  id       String   @id @default(uuid())
  eventId  String
  rank     String
  teamName String
  members  String[]
  photo    String?
  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String
  name      String
  email     String
  phone     String
  college   String
  timestamp DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  category  String
  photo     String
  gmail     String
  linkedin  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model FormSubmission {
  id        String   @id @default(uuid())
  eventId   String
  data      Json
  submitted DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model FormField {
  id       String   @id
  eventId  String
  label    String
  type     String
  required Boolean  @default(false)
  options  String[]
  order    Int      @default(0)
  Event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
